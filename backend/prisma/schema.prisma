// ===================================================
// PorLapor — schema.prisma
// DB: PostgreSQL | ORM: Prisma
// Auth: Email + Password (bcrypt)
// ===================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================================================
// ENUMS
// ===================================================

enum Role {
  USER        // masyarakat biasa, bisa buat laporan
  ADMIN       // pegawai instansi, kelola laporan
  SUPERADMIN  // bisa semua + bisa tambah/kelola admin
}

enum ReportStatus {
  PENDING      // baru masuk, belum ditinjau
  IN_REVIEW    // sedang ditinjau admin
  IN_PROGRESS  // sedang diproses instansi
  RESOLVED     // selesai ditangani
  REJECTED     // ditolak (spam / tidak valid)
}

enum Gender {
  LAKI_LAKI
  PEREMPUAN
}

enum PhotoSourceType {
  LOCAL  // file diupload langsung (disimpan di storage, url = path lokalnya)
  URL    // link eksternal langsung (e.g. dari Google, link publik, dll)
}

// ===================================================
// MODEL: User
// Satu model untuk ketiga role (USER, ADMIN, SUPERADMIN)
// ===================================================

model User {
  id        String  @id @default(uuid())
  name      String
  email     String  @unique
  password  String
  phone     String  @unique
  nik       String  @unique
  birthDate String?
  address   String
  gender    Gender

  // ── Foto Profil ──────────────────────────────────
  // photoUrl  : path file lokal (misal /uploads/users/xxx.jpg)
  //             ATAU link URL eksternal langsung
  // photoSource: membedakan keduanya agar FE / storage handler tahu
  //              cara merendernya (LOCAL = butuh base URL server,
  //              URL = langsung pakai apa adanya)
  photoUrl    String?
  photoSource PhotoSourceType?

  role     Role    @default(USER)
  isActive Boolean @default(true)

  // Relasi: siapa yang membuat akun admin ini
  // Hanya SUPERADMIN yang bisa isi field ini
  createdById   String?
  createdBy     User?  @relation("AdminCreator", fields: [createdById], references: [id])
  createdAdmins User[] @relation("AdminCreator")

  reports      Report[]
  statusLogs   ReportStatusLog[]
  spamLogs     SpamLog[]
  officialNotes OfficialNote[]
  comments     Comment[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?
  deletedAt   DateTime?

  @@map("users")
}

// ===================================================
// MODEL: Agency (Instansi Pemerintah)
// Contoh: Dinas PU, Dinas Kebersihan, Dishub, dll.
// Laporan akan di-forward ke agency berdasarkan kategori
// atau secara manual oleh admin.
// ===================================================

model Agency {
  id          String  @id @default(uuid())
  name        String
  description String?
  email       String? @unique
  phone       String?
  address     String?
  isActive    Boolean @default(true)

  // ── Foto / Logo Agency ───────────────────────────
  // Sama seperti User, bisa upload file lokal atau pakai URL eksternal
  photoUrl    String?
  photoSource PhotoSourceType?

  // Satu agency bisa menangani banyak kategori
  categories Category[]
  // Laporan yang di-assign ke agency ini
  reports    Report[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("agencies")
}

// ===================================================
// MODEL: Category (Jenis / Kategori Laporan)
// Setiap kategori terhubung ke satu agency.
// Saat laporan dibuat, report.agencyId otomatis diisi
// dari category.agencyId (bisa di-override admin).
// Contoh: Jalan Rusak → Dinas PU
//         Sampah Menumpuk → Dinas Kebersihan
// ===================================================

model Category {
  id          String  @id @default(uuid())
  name        String
  description String?
  isActive    Boolean @default(true)

  // Agency yang bertanggung jawab atas kategori ini
  agencyId String?
  agency   Agency? @relation(fields: [agencyId], references: [id])

  reports Report[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

// ===================================================
// MODEL: Report (Laporan Masyarakat)
// ===================================================

model Report {
  id          String       @id // Custom short ID, e.g. REP-A1B2C3 (generated di controller)
  title       String
  description String       @db.Text
  latitude    Float        // koordinat GPS dari device
  longitude   Float
  address     String?      // alamat hasil reverse geocoding (opsional)
  imageUrl    String?      // URL foto laporan (bukti)
  status      ReportStatus @default(PENDING)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  // Agency yang menangani laporan ini.
  // Defaultnya dari category.agencyId saat laporan dibuat,
  // tapi ADMIN / SUPERADMIN bisa override / forward manual.
  agencyId String?
  agency   Agency? @relation(fields: [agencyId], references: [id])

  statusLogs    ReportStatusLog[]
  officialNotes OfficialNote[]
  comments      Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reports")
}

// ===================================================
// MODEL: ReportStatusLog
// Riwayat perubahan status laporan oleh admin.
// Berguna untuk transparansi ke masyarakat.
// ===================================================

model ReportStatusLog {
  id     String       @id @default(uuid())
  status ReportStatus // status baru setelah diupdate
  note   String?      // catatan dari admin (opsional)

  reportId String
  report   Report @relation(fields: [reportId], references: [id])

  updatedById String
  updatedBy   User   @relation(fields: [updatedById], references: [id])

  createdAt DateTime @default(now())

  @@map("report_status_logs")
}

// ===================================================
// MODEL: OfficialNote (Tindak Lanjut Resmi)
// Hanya bisa dibuat oleh ADMIN atau SUPERADMIN.
// Bersifat resmi, tampil sebagai respons instansi
// yang terlihat oleh publik / pelapor.
// Validasi role dilakukan di middleware / controller,
// BUKAN di level Prisma.
// ===================================================

model OfficialNote {
  id      String @id @default(uuid())
  content String @db.Text

  reportId String
  report   Report @relation(fields: [reportId], references: [id])

  // Harus ADMIN atau SUPERADMIN — dicek di controller
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("official_notes")
}

// ===================================================
// MODEL: Comment (Komentar Publik)
// Bisa diisi oleh semua role termasuk USER biasa.
// Bersifat diskusi — warga lain bisa ikut berkomentar.
// ===================================================

model Comment {
  id      String @id @default(uuid())
  content String @db.Text

  reportId String
  report   Report @relation(fields: [reportId], references: [id])

  // Semua role boleh komentar
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("comments")
}

// ===================================================
// MODEL: SpamLog
// Anti-spam: maksimal 3 laporan per user per hari.
// ===================================================

model SpamLog {
  id    String   @id @default(uuid())
  date  DateTime @db.Date
  count Int      @default(1)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@map("spam_logs")
}
